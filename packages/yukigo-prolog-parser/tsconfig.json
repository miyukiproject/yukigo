{
  "compilerOptions": {
    "target": "es2025",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ES2025"],
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "composite": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": ["src"],
  "exclude": ["dist/**/*"],
  "references": [
    {
      "path": "../yukigo-ast"
    }
  ]
}
